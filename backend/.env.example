# --- Local development (copy to backend/.env) ---
# Secrets: use this file only — no Secret Manager / Cloud SQL Connector.

ENV=development

# Keep false for mock Pub/Sub + no GCP credential loading.
USE_GCP=false

# PostgreSQL — 本專案 root docker-compose 將容器 5432 對映到主機 15432。
# 若用 Docker Postgres：用下面這行（不要用 5432，否則會 connection refused）。
DATABASE_URL=postgresql+psycopg://user:password@localhost:15432/employee_safety
#
# 若本機已安裝 PostgreSQL 並直接聽 5432，可改用：
# DATABASE_URL=postgresql+psycopg://user:password@localhost:5432/employee_safety

# Redis (Docker Compose maps 6379)
REDIS_URL=redis://localhost:6379/0
REDIS_ENABLED=true

# JWT (placeholder until real auth)
JWT_SECRET=dev-only-change-me-in-production-use-strong-secret

# --- Optional: enable later for GCP / Cloud Run ---
# USE_GCP=true
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/sa.json
# GCP_PROJECT_ID=
# PUBSUB_NOTIFICATION_TOPIC=
# PUBSUB_REPORT_TOPIC=
# USE_PUBSUB_EMULATOR=true
# PUBSUB_EMULATOR_HOST=localhost:8085

# --- Production DATABASE_URL examples (switch when deploying) ---
# Cloud SQL Unix socket (Cloud Run):
# DATABASE_URL=postgresql+psycopg://DB_USER:DB_PASSWORD@/DB_NAME?host=/cloudsql/PROJECT_ID:REGION:INSTANCE_NAME
